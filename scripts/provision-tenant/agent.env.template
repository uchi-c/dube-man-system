# pc-agent env — one .env per PC. Copy to pc-agent/.env on each machine.
# Every value below must belong to THIS tenant's Supabase project.

SUPABASE_URL=https://<tenant-project-ref>.supabase.co
SUPABASE_ANON_KEY=<tenant-anon-or-publishable-key>

# Unique per machine. This is how the workstation shows up in the console
# and how remote commands (LOCK/UNLOCK/…) are routed. e.g. PC-01, PC-02.
COMPUTER_CODE=PC-01

# Heartbeat cadence in seconds.
HEARTBEAT_INTERVAL=30

# Per-tenant shared secret for the agent. Generate a fresh one per tenant —
# do NOT reuse another client's secret. e.g.  openssl rand -hex 32
AGENT_SECRET=<generate-a-unique-secret-per-tenant>
