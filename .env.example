# Uruu OS - Frontend Environment Variables
# Copy this file to '.env' and populate with your Supabase project credentials.

# Supabase Project URL (Project Settings > API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase public anon/publishable key (Project Settings > API)
VITE_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key

# Do not put PC-agent, router, service-role, or HMAC secrets in VITE_* variables.
# Browser-exposed variables are public by design. Store those secrets in Supabase Edge Function
# secrets, server environment variables, or per-device agent configuration.
